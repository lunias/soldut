# Claude Code local state
.claude/

# Build artifacts
build/
*.o
*.a
*.exe
*.dll
*.dylib
*.so
/soldut
/soldut-dbg
/soldut_editor

# Allow vendored prebuilt static libs — we commit these per platform.
# See documents/08-build-and-distribution.md.
!third_party/raylib/lib/**/*.a
!third_party/raylib/src/libraylib.a

# Editor / OS
.DS_Store
Thumbs.db
*.swp
*~
.vscode/
.idea/
__pycache__/
*.pyc

# Logs
*.log

# Generated .lvl files (editor shots + cook_maps write here; authored
# .lvl files for shipped maps land at P17/P18 and will be tracked
# then). Per-map kit textures (parallax_*.png + tiles.png) shipped
# at P16 stay tracked because we narrow the ignore to .lvl only.
assets/maps/*.lvl
assets/maps/**/*.lvl

# ComfyUI iteration scratch (P15+). Tracked inputs: workflow JSONs,
# skeletons, style anchors, crop tables, and the gostek part sheets
# (tools/comfy/gostek_part_sheets/<chassis>_gostek_v*.png — the
# shipping path since the P15 revision). Not tracked: per-run
# candidate PNGs, the extractor's preview/atlas dumps, orchestrator
# state.
tools/comfy/output/
tools/comfy/state/
tools/comfy/stumps/

# Local pipeline state files
/tmp/canonical_*.log
/tmp/canonical_*.exit
