# Claude Code local state
.claude/

# Build artifacts
build/
*.o
*.a
*.exe
*.dll
*.dylib
*.so
/soldut
/soldut-dbg
/soldut_editor

# Allow vendored prebuilt static libs — we commit these per platform.
# See documents/08-build-and-distribution.md.
!third_party/raylib/lib/**/*.a
!third_party/raylib/src/libraylib.a

# Per-user runtime state — written by the running game next to the
# binary. soldut-prefs.cfg is the wan-fixes-8 prefs file; bans.txt is
# the P09 host-set persistent ban list.
/soldut-prefs.cfg
/bans.txt

# Editor / OS
.DS_Store
Thumbs.db
*.swp
*~
.vscode/
.idea/
__pycache__/
*.pyc

# Logs
*.log

# Generated .lvl files (editor shots + cook_maps write here for
# transient test fixtures). Per-map kit textures (parallax_*.png +
# tiles.png) shipped at P16 stay tracked because we narrow the ignore
# to .lvl only.
assets/maps/*.lvl
assets/maps/**/*.lvl

# Authored .lvl files for shipped maps — exempt from the ignore above.
# P17 added foundry / slipstream / reactor / concourse via
# tools/cook_maps; P18 adds catwalk / aurora / crossfire / citadel.
!assets/maps/foundry.lvl
!assets/maps/slipstream.lvl
!assets/maps/reactor.lvl
!assets/maps/concourse.lvl
!assets/maps/catwalk.lvl
!assets/maps/aurora.lvl
!assets/maps/crossfire.lvl
!assets/maps/citadel.lvl

# Per-map preview thumbnails — generated on build by tools/cook_thumbs
# from every assets/maps/*.lvl on disk (so editor scratch + test
# fixtures also get one). Mirror the .lvl tracking policy: ignore by
# default, allow only the shipped maps' thumbs.
assets/maps/*_thumb.png
!assets/maps/foundry_thumb.png
!assets/maps/slipstream_thumb.png
!assets/maps/reactor_thumb.png
!assets/maps/concourse_thumb.png
!assets/maps/catwalk_thumb.png
!assets/maps/aurora_thumb.png
!assets/maps/crossfire_thumb.png
!assets/maps/citadel_thumb.png

# ComfyUI iteration scratch (P15+). Tracked inputs: workflow JSONs,
# skeletons, style anchors, crop tables, and the gostek part sheets
# (tools/comfy/gostek_part_sheets/<chassis>_gostek_v*.png — the
# shipping path since the P15 revision). Not tracked: per-run
# candidate PNGs, the extractor's preview/atlas dumps, orchestrator
# state.
tools/comfy/output/
tools/comfy/state/
tools/comfy/stumps/

# P19 audio sourcing scratch. Tracked: the shipped audio under
# assets/sfx/ + assets/music/, the sourcing scripts under
# tools/audio_inventory/ + tools/audio_normalize/. Not tracked:
# the source-pack ZIPs (~6 MB each Kenney pack) and their
# extracted file trees + the opengameart mp3/ogg downloads —
# all CC0 and re-derivable from the URLs in assets/credits.txt
# + tools/audio_inventory/SHOPPING.md.
assets/raw/audio/

# P19 tooling output — regenerated per run.
tools/audio_inventory/missing.txt
tools/audio_normalize/normalized.txt

# Local pipeline state files
/tmp/canonical_*.log
/tmp/canonical_*.exit

# Manual networked playtest scratch — round-by-round host/client logs
# the user captures during WAN smoke tests. Re-derivable, not for the
# repo.
/net-test logs/
