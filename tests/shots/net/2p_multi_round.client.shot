# 2p_multi_round — client. Stationary across both rounds. Casts a
# vote during summary so the fast-forward fires.

window 1280 720
out build/shots/net/client_multi_round
network connect 127.0.0.1:24043
name ClientVictim

spawn_at 800 1100

contact_sheet sheet cols 4 cell 320 180

at 140  shot t140_r1_start
at 420  shot t420_r1_summary
at 460  vote_map 0
at 1200 shot t1200_r2_playing

at 1400 end
