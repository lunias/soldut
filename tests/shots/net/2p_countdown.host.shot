# Countdown sync test — host. We override auto_start to a longer
# value (~6 s) and shoot the lobby while the countdown is mid-run
# so we can compare the host vs client display of "Match starts in
# N.Ns". The numbers should match within the broadcast window
# (~0.5 s).

window 1280 720
out build/shots/net/cd_host
network host 24031
name HostA

# Snapshots throughout the countdown. With auto_start_default = 1 s
# in shot mode the countdown is short — these scripts are named
# t-relative-to-arm.
at  30  shot t30_armed
at  90  shot t90_mid
at  120 shot t120_late
at  240 shot t240_match
at  500 end
