# P08b — host walks RIGHT on a custom NON-RESERVED-NAME map.
#
# Pairs with p08b_meet_named.client.shot. Run via the wrapper at
# tests/shots/net/run_meet_named.sh which:
#   1. Asks the editor to author <host_dir>/assets/maps/my_arena.lvl
#   2. cd's into <host_dir> (with soldut.cfg map_rotation=my_arena) and
#      launches this shot
#   3. cd's into <client_dir> (no assets/maps/) with a fresh
#      XDG_DATA_HOME (no cache) and launches the client shot
#   4. Asserts on:
#        - host registry log line `map_registry: + my_arena`
#        - host serves my_arena.lvl
#        - client downloads + caches + plays
#        - the round actually runs on `my_arena` (not Foundry)
#        - both screenshots wrote out
#
# The map authored by the editor shot has spawns at x ≈ 256 (slot 0,
# host) and x ≈ 2944 (slot 1, client) on the bottom row. Host walks
# right, client walks left, they meet near x ≈ 1600.

window 1280 720
out build/shots/net/p08b_meet_named_host
network host 24610
name HostA

at 60   shot lobby
# Round arms after 2 s soldut.cfg auto_start; first shot post-start.
at 200  shot match_start

# Walk right toward center. ~280 px/s on flat ground; 600 ticks ≈ 10s
# of running carries us ~2800 px, more than enough to reach center.
at 220  press right
at 460  release right

at 380  shot midwalk
at 520  shot meet
at 600  end

contact_sheet sheet cols 3 cell 320 180
