# 2p_anim_check — client. Stationary observer of the host's walk
# cycle. Camera sits on the local mech; the host is ~200 px to the
# left and should be clearly visible as a Trooper sprite with a
# walk-cycle leg pose.

window 1280 720
out build/shots/net/anim_client
network connect 127.0.0.1:24171
name ClientB
map slipstream

spawn_at 2500 1112
aim 2300 1080

at 150 shot t150_start_right
at 200 shot t200_running_right
at 300 shot t300_running_left
at 420 shot t420_running_right
at 550 shot t550_stopped
at 650 end
