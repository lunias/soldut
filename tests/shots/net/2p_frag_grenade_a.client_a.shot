# 2p_frag_grenade_a — client A (slot 0) throws frag grenades at B.
#
# Both clients run pure-connect against a dedicated server on
# Crossfire (built-in code map, no parallax to obscure the mechs, both
# slots spawn ~200 px apart on the same elevated platform so the
# whole grenade arc is in-view).
#
# The auto-start + countdown means MATCH starts around tick ~180 in
# the dedicated path (lobby ~1s + countdown ~1s + connect delay).
# Schedule the throws well past that.
#
# Test plan:
#   t=240   swap to secondary (frag grenades).
#   t=280   tap fire — throw grenade #1 toward B.
#   t=360   tap fire — throw grenade #2 (re-fire past 0.6 s cooldown).
#   t=440   tap fire — throw grenade #3.

window 1280 720
out build/shots/net/dedi/2p_frag_grenade_a.client_a
network connect 127.0.0.1:{{PORT}}
name ClientA
loadout - "Pulse Rifle" "Frag Grenades" Light Standard

# Aim right toward slot 1's typical Crossfire spawn (~384, 984).
aim 480 950

# Swap to secondary slot so LMB = throw. Hold for 8 ticks so the
# edge reliably propagates over the input redundancy stream (mirrors
# what 2p_secondary_fire does with fire_secondary).
at 240 press swap
at 248 release swap

# Three throws spaced past the 0.6 s fire_rate cooldown (36 ticks).
at 280 press fire
at 288 release fire
at 360 press fire
at 368 release fire
at 440 press fire
at 448 release fire

# Capture sequence — grenade #1 explodes 1.5 s = 90 ticks after
# throw → boom around t=370. Same for #2 (boom ~t=450) and #3
# (~t=530).
at 230 shot t230_pre_swap
at 260 shot t260_post_swap
at 290 shot t290_throw1
at 310 shot t310_g1_arc
at 340 shot t340_g1_late
at 370 shot t370_g1_boom
at 390 shot t390_g1_aftermath

at 360 shot t360_pre_throw2
at 400 shot t400_g2_arc
at 450 shot t450_g2_boom

at 440 shot t440_pre_throw3
at 480 shot t480_g3_arc
at 530 shot t530_g3_boom

at 560 shot t560_done
at 600 end
