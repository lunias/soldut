# M6 countdown-fix — client side. Same burst window as the host so
# the comparison sheet (run.sh composes side-by-side) shows host
# and client integer countdowns aligned to the same tick.

window 1280 720
out build/shots/net/cd_client
network connect 127.0.0.1:24031
name ClientB
loadout - "Pulse Rifle" "Sidearm" Light Standard
no_parallax
countdown_seconds 3

burst t from 60 to 290 every 10
contact_sheet sheet cols 6 cell 320 180

at 320 end
