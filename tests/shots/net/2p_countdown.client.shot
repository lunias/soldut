# Countdown sync test — client. Same screenshot ticks as host so
# we can compare the displayed countdown.

window 1280 720
out build/shots/net/cd_client
network connect 127.0.0.1:24031
name ClientB

at  30  shot t30_armed
at  90  shot t90_mid
at  120 shot t120_late
at  240 shot t240_match
at  500 end
