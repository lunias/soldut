# 2p_round_sync_banner — client. Mirror of the host shot, captures
# the same ticks so a reviewer can compare the inter-round COUNTDOWN
# banner across the wire.

window 1280 720
out build/shots/net/2p_round_sync_banner_client
network connect 127.0.0.1:24114
name ClientB

loadout - "Pulse Rifle" "Sidearm" Light Standard
spawn_at 2540 984
aim 2240 956

at 360 vote_map 0
at 380 shot t380_summary
at 460 shot t460_countdown
at 500 shot t500_countdown
at 600 shot t600_round2_active
at 700 end
