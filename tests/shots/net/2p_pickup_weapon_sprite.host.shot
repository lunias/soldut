# M6 — Weapon pickups render as atlas sprites on BOTH host and remote
# client. Pair with 2p_pickup_weapon_sprite.client.shot.
#
# Reactor is the only "real" map that ships per-flag weapon pickups
# (PLASMA_SMG ×2 at pillar base, MASS_DRIVER + RAIL_CANNON on overlooks)
# — gives the contact sheet four distinct sprite IDs to compare.

window 1280 720
out build/shots/net/host
network host 24081
name HostA
map reactor

# Capture during MATCH. Host spawns on the LEFT flank platform and
# walks RIGHT toward the central pillar so the PLASMA_SMG weapon
# pickup at x=1600 (col 50) appears in frame around t=360.
#   t=60   lobby (sanity)
#   t=240  early match — host near spawn
#   t=360  after walking right — pillar-base PLASMA_SMG in frame
at 60   shot lobby
at 240  shot match_t240

# Walk right for ~2 s so camera reaches the pillar center.
at 200  press right
at 320  release right

at 360  shot match_t360
at 540  shot summary
at 600  end

contact_sheet sheet cols 2 cell 1280 720
